{
  "name": "digi-cloak",
  "version": "1.0.0",
  "description": "A web app that hides secrets in plain sight securely in images with the help of AES encryption and LSB steganography technique.",
  "repository": "git@github.com:kaushalmeena/digi-cloak.git",
  "homepage": "https://kaushalmeena.github.io/digi-cloak/",
  "author": "Kaushal Meena <kaushal.meena1996@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "ng": "ng",
    "dev": "ng dev --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "ng deploy --base-href=/digi-cloak/",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/service-worker": "^22.0.7",
    "crypto-js": "^4.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.1.0",
    "@angular/build": "^22.0.7",
    "@angular/cli": "~22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/crypto-js": "^4.1.2",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^26.1.1",
    "angular-cli-ghpages": "2.0.3",
    "angular-eslint": "22.1.0",
    "eslint": "^10.6.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.1.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "browser": {
    "crypto": false
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
